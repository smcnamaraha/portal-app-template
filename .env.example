# ── App Configuration ──────────────────────────────────────────────────────────

# Any app-specific public env vars go here (prefix with NEXT_PUBLIC_ for client access)
# NEXT_PUBLIC_API_URL=

# ── Portal Ecosystem ───────────────────────────────────────────────────────────
# These three vars are auto-injected by the portal during app provisioning.
# DO NOT hardcode values here — they are set in Coolify's environment config.
# For local development, copy these values from the portal's app settings page.

# Full URL to the portal's ecosystem API (e.g. https://portal.underlay.io/api/ecosystem)
ECOSYSTEM_API_URL=

# This app's ecosystem API key (eco_... prefix). Injected at provisioning time.
ECOSYSTEM_API_KEY=

# This app's slug (e.g. sc-scout). Used to identify the publisher in the ecosystem.
APP_SLUG=
